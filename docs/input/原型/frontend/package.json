{
  "name": "scholarsense-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc -b --noEmit",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\""
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.8",
    "echarts": "^5.5.1",
    "element-plus": "^2.7.8",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@vitejs/plugin-vue": "^5.0.4",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vue-tsc": "^2.0.14"
  }
}
