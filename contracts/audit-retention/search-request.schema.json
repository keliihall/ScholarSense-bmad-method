{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/audit-retention/search-request-1.0.0.schema.json",
  "title": "Audit search request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "view", "page", "size"],
  "properties": {
    "schemaVersion": {"const": "AUDIT-SEARCH-REQUEST-1.0.0"},
    "view": {"enum": ["business", "technical"]},
    "actorRef": {"type": "string", "minLength": 1, "maxLength": 256},
    "objectType": {"type": "string", "minLength": 1, "maxLength": 64},
    "objectRef": {"type": "string", "minLength": 1, "maxLength": 256},
    "action": {"type": "string", "pattern": "^[a-z][a-z0-9.-]{2,127}$"},
    "occurredFrom": {"type": "string", "format": "date-time"},
    "occurredTo": {"type": "string", "format": "date-time"},
    "outcome": {"enum": ["accepted", "rejected", "failed", "succeeded"]},
    "traceId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,127}$"},
    "page": {"type": "integer", "minimum": 0},
    "size": {"type": "integer", "minimum": 1, "maximum": 100},
    "asOfSequence": {"type": "integer", "minimum": 0}
  }
}
