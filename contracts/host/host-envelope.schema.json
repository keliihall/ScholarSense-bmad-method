{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.scholarsense.invalid/host/host-envelope.schema.json",
  "title": "HIP-1.0.0 host message envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "eventType", "messageId", "correlationId", "issuedAt", "nonce", "payload"],
  "properties": {
    "schemaVersion": {"const": "HIP-1.0.0"},
    "eventType": {
      "enum": ["host.ready", "auth.changed", "navigate.requested", "logout.requested", "theme.changed"]
    },
    "messageId": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "correlationId": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "issuedAt": {"type": "string", "format": "date-time"},
    "nonce": {"type": "string", "pattern": "^[A-Za-z0-9_-]{32,128}$"},
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bootstrapCode": {"type": "string", "pattern": "^hb_[A-Za-z0-9_-]{43,86}$"},
        "targetRouteId": {"type": "string", "pattern": "^shell\\.(home|session)$"},
        "theme": {"enum": ["light", "dark", "system"]}
      }
    }
  }
}
