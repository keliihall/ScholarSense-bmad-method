{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.scholarsense.invalid/audit-ledger/alert.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "alertId", "findingId", "event", "code", "severity", "policyVersion", "hashProfileVersion", "sequenceRange", "sourceRange", "safeDigest", "traceId", "occurredAt", "detectedAt", "runbookRef"],
  "properties": {
    "schemaVersion": {"const": "AUDIT-INTEGRITY-ALERT-1.0.0"},
    "alertId": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "findingId": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "event": {"enum": ["active", "resolved"]},
    "code": {"type": "string", "pattern": "^AUDIT_[A-Z0-9_]+$"},
    "severity": {"enum": ["warning", "critical"]},
    "policyVersion": {"const": "AUDIT-INGESTION-POLICY-1.0.0"},
    "hashProfileVersion": {"const": "AUDIT-LEDGER-HASH-1.0.0"},
    "sequenceRange": {"type": ["string", "null"]},
    "sourceRange": {"type": ["string", "null"]},
    "safeDigest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "traceId": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "occurredAt": {"type": "string", "format": "date-time"},
    "detectedAt": {"type": "string", "format": "date-time"},
    "runbookRef": {"type": "string", "pattern": "^runbook://audit/[a-z0-9-]{3,80}$"}
  }
}
