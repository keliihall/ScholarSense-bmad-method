{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.scholarsense.invalid/audit-ledger/ledger-record.schema.json",
  "title": "ScholarSense Audit Ledger Record v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "ledgerSequence", "previousHash", "entryHash", "hashProfileVersion", "auditId", "sourceEventId", "producerModule", "eventType", "eventSchemaVersion", "factSchemaVersion", "sourceCreatedAt", "collectedAt", "traceId", "aggregateVersion", "payloadFingerprint", "payload"],
  "properties": {
    "schemaVersion": {"const": "AUDIT-LEDGER-RECORD-1.0.0"},
    "ledgerSequence": {"type": "integer", "minimum": 1},
    "previousHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "entryHash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "hashProfileVersion": {"const": "AUDIT-LEDGER-HASH-1.0.0"},
    "auditId": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "sourceEventId": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "producerModule": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
    "eventType": {"type": "string", "pattern": "^[a-z][a-z0-9.-]{2,127}$"},
    "eventSchemaVersion": {"const": "LOCAL-AUDIT-OUTBOX-1.0.0"},
    "factSchemaVersion": {"const": "LOCAL-AUDIT-FACT-1.0.0"},
    "sourceCreatedAt": {"type": "string", "format": "date-time"},
    "collectedAt": {"type": "string", "format": "date-time"},
    "traceId": {"type": "string", "pattern": "^[0-9a-f]{32}$"},
    "aggregateVersion": {"type": ["integer", "null"], "minimum": 1},
    "payloadFingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "payload": {"type": "object"}
  }
}
