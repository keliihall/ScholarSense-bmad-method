{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.scholarsense.invalid/audit/action-catalog.schema.json",
  "title": "ScholarSense audit action catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "outcomes", "reasonCodes", "actions"],
  "properties": {
    "$schema": {"type": "string"},
    "version": {"const": "AUDIT-ACTION-CATALOG-1.0.0"},
    "outcomes": {"type": "array", "uniqueItems": true, "items": {"enum": ["accepted", "rejected"]}},
    "reasonCodes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,127}$"}},
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "ownerModule", "activationStory", "status", "allowedOutcomes", "allowedReasonCodes", "allowedResults"],
        "properties": {
          "code": {"type": "string", "pattern": "^[a-z][a-z0-9.-]{2,127}$"},
          "ownerModule": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
          "activationStory": {"type": "string", "pattern": "^[0-9]+(?:-[0-9]+[a-z]?)+$"},
          "status": {"enum": ["active", "reserved"]},
          "allowedOutcomes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["accepted", "rejected"]}},
          "allowedReasonCodes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,127}$"}},
          "allowedResults": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["outcome", "reasonCode"],
              "properties": {
                "outcome": {"enum": ["accepted", "rejected"]},
                "reasonCode": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,127}$"}
              }
            }
          }
        }
      }
    }
  }
}
