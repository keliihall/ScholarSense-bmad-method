{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.scholarsense.invalid/identity/bootstrap-exchange.schema.json",
  "title": "Single-use host bootstrap exchange",
  "type": "object",
  "additionalProperties": false,
  "required": ["bootstrapCode", "audience", "origin"],
  "properties": {
    "bootstrapCode": {"type": "string", "pattern": "^hb_[A-Za-z0-9_-]{43,86}$"},
    "audience": {"const": "scholarsense-web"},
    "origin": {"type": "string", "pattern": "^https://[A-Za-z0-9.-]+$"}
  }
}
