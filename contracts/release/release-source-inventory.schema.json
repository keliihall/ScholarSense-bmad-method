{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/release-source-inventory.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "RELEASE-SOURCE-INVENTORY-1.0.0"},
    "repositoryUrl": {"type": "string", "minLength": 1},
    "repositoryId": {"type": "integer", "minimum": 1},
    "sourceCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "gitTreeOid": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "fileCount": {"type": "integer", "minimum": 1},
    "normalizedManifestSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "normalization": {"type": "string", "minLength": 3},
    "includedScopes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "inventoryExclusion": {"type": "string", "minLength": 3},
    "createdFrom": {"type": "string", "minLength": 1},
    "historicalInventoryDisposition": {"type": "string", "minLength": 10}
  },
  "required": ["version", "repositoryUrl", "repositoryId", "sourceCommit", "gitTreeOid", "fileCount", "normalizedManifestSha256", "normalization", "includedScopes", "inventoryExclusion", "createdFrom", "historicalInventoryDisposition"],
  "additionalProperties": false
}
