{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/release-manifest.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "RELEASE-MANIFEST-1.0.0"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "sourceCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sourceInventory": {"$ref": "#/$defs/reference"},
    "buildManifest": {"$ref": "#/$defs/reference"},
    "buildAttempts": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/attempt"}},
    "canonicalizationProfile": {"const": "SCHOLARSENSE-CANONICAL-JSON-1.0.0"},
    "baselineApprovals": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"$ref": "#/$defs/baseline"}},
    "runtimeEvidence": {"type": "array", "minItems": 4, "maxItems": 4, "uniqueItems": true, "items": {"$ref": "#/$defs/runtime"}},
    "controlledInputs": {"type": "array", "minItems": 16, "maxItems": 16, "uniqueItems": true, "items": {"$ref": "#/$defs/reference"}},
    "locks": {"type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true, "items": {"$ref": "#/$defs/reference"}},
    "artifacts": {"type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true, "items": {"$ref": "#/$defs/artifact"}},
    "evidence": {"type": "array", "minItems": 14, "uniqueItems": true, "items": {"$ref": "#/$defs/evidence"}},
    "frozenAt": {"type": "string", "format": "date-time"}
  },
  "required": ["version", "releaseVersion", "sourceCommit", "sourceInventory", "buildManifest", "buildAttempts", "canonicalizationProfile", "baselineApprovals", "runtimeEvidence", "controlledInputs", "locks", "artifacts", "evidence", "frozenAt"],
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "format": "uri"},
        "mediaType": {"type": "string", "minLength": 3},
        "size": {"type": "integer", "minimum": 1},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ociDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      },
      "required": ["id", "version", "uri", "mediaType", "size", "binarySha256", "ociDigest"],
      "additionalProperties": false
    },
    "attempt": {
      "type": "object",
      "properties": {
        "attempt": {"type": "integer", "minimum": 1, "maximum": 2},
        "buildInputSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "artifactSetSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "required": ["attempt", "buildInputSha256", "artifactSetSha256"],
      "additionalProperties": false
    },
    "baseline": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "format": "uri"},
        "mediaType": {"type": "string", "minLength": 3},
        "size": {"type": "integer", "minimum": 1},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ociDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "status": {"const": "approved"}
      },
      "required": ["id", "version", "uri", "mediaType", "size", "binarySha256", "ociDigest", "status"],
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["passed", "pending-story-execution", "not-applicable"]},
        "evidenceIds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "decisionId": {"type": "string", "minLength": 1},
        "ownerStory": {"type": "string", "minLength": 1},
        "runtimeEvidenceClaim": {"const": "none"}
      },
      "required": ["id", "status"],
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"const": "artifact"},
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "format": "uri"},
        "mediaType": {"type": "string", "minLength": 3},
        "size": {"type": "integer", "minimum": 1},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ociDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      },
      "required": ["id", "kind", "name", "version", "uri", "mediaType", "size", "binarySha256", "ociDigest"],
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "enum": ["artifact-signature", "brand-asset-manifest", "formal-web-report", "provenance", "sbom", "sbom-attestation", "ui-token-manifest", "visual-baseline", "vulnerability-scan"]},
        "version": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "format": "uri"},
        "mediaType": {"type": "string", "minLength": 3},
        "size": {"type": "integer", "minimum": 1},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ociDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "subjectBinarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "required": ["id", "kind", "version", "uri", "mediaType", "size", "binarySha256", "ociDigest", "subjectBinarySha256"],
      "additionalProperties": false
    }
  }
}
