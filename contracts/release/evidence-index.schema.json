{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/evidence-index.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "EVIDENCE-INDEX-1.0.0"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "subjectManifestSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "releaseManifest": {"$ref": "#/$defs/reference"},
    "manifestSignature": {"$ref": "#/$defs/signature"},
    "evidence": {"type": "array", "minItems": 16, "uniqueItems": true, "items": {"$ref": "#/$defs/node"}},
    "versionBindings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/versionBinding"}},
    "createdAt": {"type": "string", "format": "date-time"}
  },
  "required": ["version", "releaseVersion", "subjectManifestSha256", "releaseManifest", "manifestSignature", "evidence", "versionBindings", "createdAt"],
  "additionalProperties": false,
  "$defs": {
    "reference": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "minLength": 1},
        "mediaType": {"type": "string", "minLength": 3},
        "size": {"type": "integer", "minimum": 1},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ociDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      },
      "required": ["id", "version", "uri", "mediaType", "size", "binarySha256", "ociDigest"],
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "enum": ["artifact", "artifact-signature", "brand-asset-manifest", "formal-web-report", "host-sso-runtime-evidence", "provenance", "sbom-attestation", "sbom-cyclonedx", "sbom-spdx", "ui-token-manifest", "visual-baseline", "vulnerability-scan"]},
        "stage": {"type": "string", "enum": ["artifact", "artifact-evidence", "artifact-signature"]},
        "version": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "minLength": 1},
        "mediaType": {"type": "string", "minLength": 3},
        "size": {"type": "integer", "minimum": 1},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ociDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "subjectBinarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "dependsOn": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "required": ["id", "kind", "stage", "version", "uri", "mediaType", "size", "binarySha256", "ociDigest", "subjectBinarySha256", "dependsOn"],
      "additionalProperties": false
    },
    "signature": {
      "type": "object",
      "properties": {
        "id": {"const": "manifest-signature"},
        "kind": {"const": "manifest-signature"},
        "stage": {"const": "manifest-signature"},
        "version": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "minLength": 1},
        "mediaType": {"type": "string", "minLength": 3},
        "size": {"type": "integer", "minimum": 1},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "ociDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "subjectBinarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "dependsOn": {"type": "array", "minItems": 1, "maxItems": 1, "uniqueItems": true, "items": {"const": "release-manifest"}}
      },
      "required": ["id", "kind", "stage", "version", "uri", "mediaType", "size", "binarySha256", "ociDigest", "subjectBinarySha256", "dependsOn"],
      "additionalProperties": false
    },
    "versionBinding": {
      "type": "object",
      "properties": {
        "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "manifestSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "required": ["releaseVersion", "manifestSha256"],
      "additionalProperties": false
    }
  }
}
