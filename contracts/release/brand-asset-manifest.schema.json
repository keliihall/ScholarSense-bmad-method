{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/brand-asset-manifest.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "BRAND-ASSET-MANIFEST-1.0.0"},
    "assets": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/asset"}, "uniqueItems": true}
  },
  "required": ["version", "assets"],
  "additionalProperties": false,
  "$defs": {
    "asset": {
      "type": "object",
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "uri": {"type": "string", "minLength": 1},
        "mediaType": {"type": "string", "minLength": 3},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "license": {"type": "string", "minLength": 2}
      },
      "required": ["name", "uri", "mediaType", "binarySha256", "license"],
      "additionalProperties": false
    }
  }
}
