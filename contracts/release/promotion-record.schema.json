{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/promotion-record.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "PROMOTION-RECORD-1.0.0"},
    "releaseVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "fromEnvironment": {"type": "string", "enum": ["candidate", "stage", "production"]},
    "targetEnvironment": {"type": "string", "enum": ["stage", "production"]},
    "sourceArtifactUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
    "targetArtifactUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
    "targetTagUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+:release-[0-9]+\\.[0-9]+\\.[0-9]+-[0-9a-f]{16}$"},
    "artifactOciDigest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "sbomUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
    "attestationUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
    "webUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
    "manifestUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
    "manifestSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "signatureUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
    "evidenceIndexUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
    "evidenceIndexSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "verifierIdentity": {"type": "string", "minLength": 2},
    "verifiedAt": {"type": "string", "format": "date-time"},
    "evidenceExpiresAt": {"type": "string", "format": "date-time"},
    "actor": {"type": "string", "minLength": 2},
    "approver": {"type": "string", "minLength": 2},
    "approvalEnvironmentId": {"type": "integer", "minimum": 1},
    "approvalEvidenceUri": {"type": "string", "pattern": "^https://api\\.github\\.com/repos/keliihall/ScholarSense-bmad-method/actions/runs/[0-9]+/approvals$"},
    "approvalEvidenceSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runId": {"type": "string", "pattern": "^[0-9]+$"},
    "runAttempt": {"type": "integer", "minimum": 1},
    "result": {"type": "string", "enum": ["promoted", "replayed", "conflict", "rejected"]},
    "createdAt": {"type": "string", "format": "date-time"},
    "ledgerUri": {"type": "string", "minLength": 1},
    "rollbackOfLedgerUri": {"type": "string", "minLength": 1}
  },
  "required": ["version", "releaseVersion", "fromEnvironment", "targetEnvironment", "sourceArtifactUri", "targetArtifactUri", "targetTagUri", "artifactOciDigest", "sbomUri", "attestationUri", "webUri", "manifestUri", "manifestSha256", "signatureUri", "evidenceIndexUri", "evidenceIndexSha256", "verifierIdentity", "verifiedAt", "evidenceExpiresAt", "actor", "approver", "approvalEnvironmentId", "approvalEvidenceUri", "approvalEvidenceSha256", "runId", "runAttempt", "result", "createdAt", "ledgerUri"],
  "additionalProperties": false
}
