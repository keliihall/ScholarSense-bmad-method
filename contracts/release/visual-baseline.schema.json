{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/visual-baseline.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "VGB-1.0.0"},
    "status": {"const": "approved"},
    "approvedByUxBrand": {"type": "string", "minLength": 2},
    "approvedByWebQa": {"type": "string", "minLength": 2},
    "effectiveAt": {"type": "string", "format": "date-time"},
    "approvedArtifactSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "testEnvironmentVersion": {"const": "TEST-ENV-1.0.0"},
    "testEnvironmentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runnerImageSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "fontManifestSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "deviceScaleFactor": {"const": 1},
    "locale": {"const": "zh-CN"},
    "timezone": {"const": "Asia/Shanghai"},
    "clock": {"const": "2026-07-19T01:00:00Z"},
    "colorScheme": {"const": "light"},
    "reducedMotion": {"const": "reduce"},
    "networkProfile": {"const": "frozen-local-static-only"},
    "dataProfile": {"const": "deterministic-baseline-fixture"},
    "thresholdPermille": {"const": 100},
    "maxDiffPixels": {"const": 0},
    "animations": {"const": "disabled"},
    "caret": {"const": "hide"},
    "scale": {"const": "css"},
    "cells": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/cell"}, "uniqueItems": true}
  },
  "required": ["version", "status", "approvedByUxBrand", "approvedByWebQa", "effectiveAt", "approvedArtifactSha256", "testEnvironmentVersion", "testEnvironmentSha256", "runnerImageSha256", "fontManifestSha256", "deviceScaleFactor", "locale", "timezone", "clock", "colorScheme", "reducedMotion", "networkProfile", "dataProfile", "thresholdPermille", "maxDiffPixels", "animations", "caret", "scale", "cells"],
  "additionalProperties": false,
  "$defs": {
    "cell": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "pattern": "^(chrome|edge)-(current|previous)-(desktop-reference|desktop-minimum)$"},
        "browser": {"type": "string", "enum": ["chrome", "edge"]},
        "channel": {"type": "string", "enum": ["current", "previous"]},
        "major": {"type": "integer", "minimum": 149, "maximum": 150},
        "browserVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "browserArtifactSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "executableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "osBuild": {"const": "macOS 26.5.2 build 25F84 arm64"},
        "viewport": {"type": "string", "enum": ["desktop-reference", "desktop-minimum"]},
        "width": {"type": "integer", "minimum": 1366, "maximum": 1440},
        "height": {"type": "integer", "minimum": 768, "maximum": 900},
        "deviceScaleFactor": {"const": 1},
        "locale": {"const": "zh-CN"},
        "timezone": {"const": "Asia/Shanghai"},
        "clock": {"const": "2026-07-19T01:00:00Z"},
        "networkProfile": {"const": "frozen-local-static-only"},
        "dataProfile": {"const": "deterministic-baseline-fixture"},
        "goldenUri": {"type": "string", "pattern": "^ghcr\\.io/[a-z0-9_.-]+/[a-z0-9_./-]+@sha256:[0-9a-f]{64}$"},
        "goldenPath": {"type": "string", "pattern": "^goldens/(chrome|edge)-(current|previous)-(desktop-reference|desktop-minimum)\\.png$"},
        "goldenScreenshotSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "required": ["id", "browser", "channel", "major", "browserVersion", "browserArtifactSha256", "executableSha256", "osBuild", "viewport", "width", "height", "deviceScaleFactor", "locale", "timezone", "clock", "networkProfile", "dataProfile", "goldenUri", "goldenPath", "goldenScreenshotSha256"],
      "additionalProperties": false
    }
  }
}
