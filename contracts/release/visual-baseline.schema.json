{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/visual-baseline.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "VGB-1.0.0"},
    "status": {"const": "approved"},
    "approvedByUxBrand": {"type": "string", "minLength": 2},
    "approvedByWebQa": {"type": "string", "minLength": 2},
    "effectiveAt": {"type": "string", "format": "date-time"},
    "deviceScaleFactor": {"const": 1},
    "locale": {"const": "zh-CN"},
    "timezone": {"const": "Asia/Shanghai"},
    "thresholdPermille": {"const": 100},
    "maxDiffPixels": {"const": 0},
    "cells": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/cell"}, "uniqueItems": true}
  },
  "required": ["version", "status", "approvedByUxBrand", "approvedByWebQa", "effectiveAt", "deviceScaleFactor", "locale", "timezone", "thresholdPermille", "maxDiffPixels", "cells"],
  "additionalProperties": false,
  "$defs": {
    "cell": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "minLength": 3},
        "osBuild": {"type": "string", "minLength": 3},
        "browserVersion": {"type": "string", "minLength": 3},
        "executableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "goldenUri": {"type": "string", "format": "uri"},
        "goldenScreenshotSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "required": ["id", "osBuild", "browserVersion", "executableSha256", "goldenUri", "goldenScreenshotSha256"],
      "additionalProperties": false
    }
  }
}
