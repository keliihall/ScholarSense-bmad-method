{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/toolchain-lock.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "TOOLCHAIN-LOCK-1.0.0"},
    "tools": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/tool"}},
    "actions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/action"}}
  },
  "required": ["version", "tools", "actions"],
  "additionalProperties": false,
  "$defs": {
    "tool": {
      "type": "object",
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "binarySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "sourceUri": {"type": "string", "minLength": 1}
      },
      "required": ["name", "version", "binarySha256", "sourceUri"],
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "properties": {
        "repository": {"type": "string", "minLength": 3},
        "releaseVersion": {"type": "string", "pattern": "^v?[0-9]+\\.[0-9]+\\.[0-9]+$"},
        "actionCommitOid": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      },
      "required": ["repository", "releaseVersion", "actionCommitOid"],
      "additionalProperties": false
    }
  }
}
