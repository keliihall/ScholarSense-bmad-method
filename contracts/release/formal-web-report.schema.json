{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarsense.suda.edu.cn/contracts/release/formal-web-report.schema.json",
  "type": "object",
  "properties": {
    "version": {"const": "FORMAL-WEB-REPORT-1.0.0"},
    "subjectArtifactSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "buildManifestSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "testEnvironmentSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runnerImageSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "matrix": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/cell"}, "uniqueItems": true},
    "result": {"type": "string", "enum": ["passed", "failed", "not-run"]},
    "createdAt": {"type": "string", "format": "date-time"}
  },
  "required": ["version", "subjectArtifactSha256", "buildManifestSha256", "testEnvironmentSha256", "runnerImageSha256", "matrix", "result", "createdAt"],
  "additionalProperties": false,
  "$defs": {
    "cell": {
      "type": "object",
      "properties": {
        "browser": {"type": "string", "enum": ["chrome", "edge"]},
        "major": {"type": "integer", "minimum": 149, "maximum": 150},
        "viewport": {"type": "string", "minLength": 3},
        "executableSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "actualScreenshotSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "goldenScreenshotSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "diffPixels": {"type": "integer", "minimum": 0},
        "result": {"type": "string", "enum": ["passed", "failed"]}
      },
      "required": ["browser", "major", "viewport", "executableSha256", "actualScreenshotSha256", "goldenScreenshotSha256", "diffPixels", "result"],
      "additionalProperties": false
    }
  }
}
