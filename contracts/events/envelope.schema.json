{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.scholarsense.invalid/events/envelope.schema.json",
  "title": "ScholarSense CloudEvents envelope seed",
  "type": "object",
  "required": ["specversion", "id", "source", "type", "time", "data"],
  "properties": {
    "specversion": {
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "format": "uri-reference"
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*\\.v[1-9][0-9]*$"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "subject": {
      "type": "string"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "traceparent": {
      "type": "string"
    },
    "data": {}
  },
  "additionalProperties": true
}

