SCHOLARSENSE_AUDIT_HASH_PROFILE_REF=config://test/audit-ledger-hash-1-0-0
SCHOLARSENSE_AUDIT_COLLECTOR_REF=config://test/audit-collector-1-0-0
SCHOLARSENSE_AUDIT_VERIFIER_REF=config://test/audit-verifier-1-0-0
SCHOLARSENSE_AUDIT_ALERT_TRANSPORT_REF=config://test/audit-alert-structured-log-1-0-0
SCHOLARSENSE_AUDIT_METRIC_BINDING_REF=config://test/audit-micrometer-1-0-0
