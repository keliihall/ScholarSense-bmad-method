# Non-secret names and reserved example values only.
SCHOLARSENSE_ENV=test
SCHOLARSENSE_ROLE=web-api
SCHOLARSENSE_ACCOUNT_REF=account://test/example-school
SCHOLARSENSE_DATABASE_REF=database://test/scholarsense
SCHOLARSENSE_SECRET_REF=secret://test/scholarsense
SCHOLARSENSE_STORAGE_NAMESPACE=scholarsense-test
SCHOLARSENSE_EXTERNAL_BASE_URI=https://test.example.invalid
SCHOLARSENSE_HTTP_PORT=8080
SCHOLARSENSE_IDENTITY_ENABLED=true
SCHOLARSENSE_AUDIT_LEDGER_ENABLED=false
SCHOLARSENSE_CLOCK_SOURCE_REF=config://test/campus-ntp-a
