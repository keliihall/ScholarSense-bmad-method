# Non-secret names and reserved example values only.
SCHOLARSENSE_ENV=stage
SCHOLARSENSE_ROLE=web-api
SCHOLARSENSE_ACCOUNT_REF=account://stage/example-school
SCHOLARSENSE_DATABASE_REF=database://stage/scholarsense
SCHOLARSENSE_SECRET_REF=secret://stage/scholarsense
SCHOLARSENSE_STORAGE_NAMESPACE=scholarsense-stage
SCHOLARSENSE_EXTERNAL_BASE_URI=https://stage.example.invalid
SCHOLARSENSE_HTTP_PORT=8080
SCHOLARSENSE_IDENTITY_ENABLED=true
SCHOLARSENSE_AUDIT_LEDGER_ENABLED=false
SCHOLARSENSE_CLOCK_SOURCE_REF=config://stage/campus-ntp-a
SCHOLARSENSE_AUDIT_INGESTION_POLICY_REF=config://stage/audit-ingestion-policy-1-0-0
SCHOLARSENSE_AUDIT_HASH_PROFILE_REF=config://stage/audit-ledger-hash-1-0-0
SCHOLARSENSE_AUDIT_COLLECTOR_REF=config://stage/audit-collector-1-0-0
SCHOLARSENSE_AUDIT_VERIFIER_REF=config://stage/audit-verifier-1-0-0
SCHOLARSENSE_AUDIT_ALERT_TRANSPORT_REF=config://stage/audit-alert-structured-log-1-0-0
SCHOLARSENSE_AUDIT_METRIC_BINDING_REF=config://stage/audit-micrometer-1-0-0
SCHOLARSENSE_AUDIT_RETENTION_CAPABILITY_REF=config://stage/audit-retention-capability-1-0-0
