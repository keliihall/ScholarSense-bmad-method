# Non-secret names and reserved example values only.
SCHOLARSENSE_ENV=prod
SCHOLARSENSE_ROLE=web-api
SCHOLARSENSE_ACCOUNT_REF=account://prod/example-school
SCHOLARSENSE_DATABASE_REF=database://prod/scholarsense
SCHOLARSENSE_SECRET_REF=secret://prod/scholarsense
SCHOLARSENSE_STORAGE_NAMESPACE=scholarsense-prod
SCHOLARSENSE_EXTERNAL_BASE_URI=https://prod.example.invalid
SCHOLARSENSE_HTTP_PORT=8080
SCHOLARSENSE_IDENTITY_ENABLED=true
SCHOLARSENSE_AUDIT_LEDGER_ENABLED=false
SCHOLARSENSE_CLOCK_SOURCE_REF=config://prod/campus-ntp-a
SCHOLARSENSE_AUDIT_INGESTION_POLICY_REF=config://prod/audit-ingestion-policy-1-0-0
SCHOLARSENSE_AUDIT_HASH_PROFILE_REF=config://prod/audit-ledger-hash-1-0-0
SCHOLARSENSE_AUDIT_COLLECTOR_REF=config://prod/audit-collector-1-0-0
SCHOLARSENSE_AUDIT_VERIFIER_REF=config://prod/audit-verifier-1-0-0
SCHOLARSENSE_AUDIT_ALERT_TRANSPORT_REF=config://prod/audit-alert-structured-log-1-0-0
SCHOLARSENSE_AUDIT_METRIC_BINDING_REF=config://prod/audit-micrometer-1-0-0
SCHOLARSENSE_AUDIT_RETENTION_CAPABILITY_REF=config://prod/audit-retention-capability-1-0-0
