# Non-secret names and reserved example values only.
SCHOLARSENSE_ENV=dev
SCHOLARSENSE_ROLE=web-api
SCHOLARSENSE_ACCOUNT_REF=account://dev/example-school
SCHOLARSENSE_DATABASE_REF=database://dev/scholarsense
SCHOLARSENSE_SECRET_REF=secret://dev/scholarsense
SCHOLARSENSE_STORAGE_NAMESPACE=scholarsense-dev
SCHOLARSENSE_EXTERNAL_BASE_URI=https://dev.example.invalid
SCHOLARSENSE_HTTP_PORT=8080
SCHOLARSENSE_IDENTITY_ENABLED=true
SCHOLARSENSE_AUDIT_LEDGER_ENABLED=false
SCHOLARSENSE_CLOCK_SOURCE_REF=config://dev/campus-ntp-a
SCHOLARSENSE_AUDIT_INGESTION_POLICY_REF=config://dev/audit-ingestion-policy-1-0-0
SCHOLARSENSE_AUDIT_HASH_PROFILE_REF=config://dev/audit-ledger-hash-1-0-0
SCHOLARSENSE_AUDIT_COLLECTOR_REF=config://dev/audit-collector-1-0-0
SCHOLARSENSE_AUDIT_VERIFIER_REF=config://dev/audit-verifier-1-0-0
SCHOLARSENSE_AUDIT_ALERT_TRANSPORT_REF=config://dev/audit-alert-structured-log-1-0-0
SCHOLARSENSE_AUDIT_METRIC_BINDING_REF=config://dev/audit-micrometer-1-0-0
