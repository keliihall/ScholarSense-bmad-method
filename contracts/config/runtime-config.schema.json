{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.scholarsense.invalid/runtime-config.schema.json",
  "title": "ScholarSense non-secret runtime configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "SCHOLARSENSE_ENV",
    "SCHOLARSENSE_ROLE",
    "SCHOLARSENSE_ACCOUNT_REF",
    "SCHOLARSENSE_DATABASE_REF",
    "SCHOLARSENSE_SECRET_REF",
    "SCHOLARSENSE_STORAGE_NAMESPACE",
    "SCHOLARSENSE_EXTERNAL_BASE_URI",
    "SCHOLARSENSE_IDENTITY_ENABLED",
    "SCHOLARSENSE_AUDIT_LEDGER_ENABLED"
  ],
  "properties": {
    "SCHOLARSENSE_ENV": {
      "type": "string",
      "enum": ["dev", "test", "stage", "prod"]
    },
    "SCHOLARSENSE_ROLE": {
      "type": "string",
      "enum": ["web-api", "worker"]
    },
    "SCHOLARSENSE_ACCOUNT_REF": {
      "type": "string",
      "pattern": "^account://(dev|test|stage|prod)/[a-z0-9-]+$",
      "description": "Environment-scoped account reference; never an account credential."
    },
    "SCHOLARSENSE_DATABASE_REF": {
      "type": "string",
      "pattern": "^database://(dev|test|stage|prod)/[a-z0-9-]+$",
      "description": "Environment-scoped database configuration reference; never a connection credential."
    },
    "SCHOLARSENSE_SECRET_REF": {
      "type": "string",
      "pattern": "^secret://(dev|test|stage|prod)/[a-z0-9-]+$",
      "description": "Environment-scoped key reference only; referenced material is never stored in this object."
    },
    "SCHOLARSENSE_STORAGE_NAMESPACE": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-(dev|test|stage|prod)$"
    },
    "SCHOLARSENSE_EXTERNAL_BASE_URI": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://(dev|test|stage|prod)(?:\\.[a-z0-9-]+)*\\.invalid(?:/[^#]*)?$"
    },
    "SCHOLARSENSE_HTTP_PORT": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$",
      "default": "8080"
    },
    "SCHOLARSENSE_IDENTITY_ENABLED": {
      "type": "string",
      "enum": ["true", "false"]
    },
    "SCHOLARSENSE_AUDIT_LEDGER_ENABLED": {
      "type": "string",
      "enum": ["true", "false"]
    },
    "SCHOLARSENSE_CLOCK_SOURCE_REF": {
      "type": "string",
      "pattern": "^config://(dev|test|stage|prod)/[a-z0-9-]+$",
      "description": "Environment-scoped trusted-time evidence source binding."
    },
    "SCHOLARSENSE_AUDIT_INGESTION_POLICY_REF": {
      "type": "string",
      "pattern": "^config://(dev|test|stage|prod)/audit-ingestion-policy-1-0-0$",
      "description": "Environment-scoped immutable ingestion and backlog policy binding."
    },
    "SCHOLARSENSE_AUDIT_HASH_PROFILE_REF": {
      "type": "string",
      "pattern": "^config://(dev|test|stage|prod)/audit-ledger-hash-1-0-0$",
      "description": "Environment-scoped immutable ledger hash profile binding."
    },
    "SCHOLARSENSE_AUDIT_COLLECTOR_REF": {
      "type": "string",
      "pattern": "^config://(dev|test|stage|prod)/audit-collector-1-0-0$",
      "description": "Environment-scoped collector scheduling and lease configuration binding."
    },
    "SCHOLARSENSE_AUDIT_VERIFIER_REF": {
      "type": "string",
      "pattern": "^config://(dev|test|stage|prod)/audit-verifier-1-0-0$",
      "description": "Environment-scoped verifier scheduling and scan configuration binding."
    },
    "SCHOLARSENSE_AUDIT_ALERT_TRANSPORT_REF": {
      "type": "string",
      "pattern": "^config://(dev|test|stage|prod)/audit-alert-structured-log-1-0-0$",
      "description": "Environment-scoped required alert transport binding."
    },
    "SCHOLARSENSE_AUDIT_METRIC_BINDING_REF": {
      "type": "string",
      "pattern": "^config://(dev|test|stage|prod)/audit-micrometer-1-0-0$",
      "description": "Environment-scoped required metrics backend binding."
    },
    "SCHOLARSENSE_AUDIT_RETENTION_CAPABILITY_REF": {
      "type": "string",
      "pattern": "^config://(dev|test|stage|prod)/audit-retention-capability-1-0-0$",
      "description": "Capability manifest binding; v1 records conformance true while production authorization/archive remain disabled."
    }
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          {"properties": {"SCHOLARSENSE_IDENTITY_ENABLED": {"const": "true"}}},
          {"properties": {"SCHOLARSENSE_AUDIT_LEDGER_ENABLED": {"const": "true"}}}
        ]
      },
      "then": {"required": ["SCHOLARSENSE_CLOCK_SOURCE_REF"]}
    },
    {
      "if": {
        "properties": {"SCHOLARSENSE_AUDIT_LEDGER_ENABLED": {"const": "true"}},
        "required": ["SCHOLARSENSE_AUDIT_LEDGER_ENABLED"]
      },
      "then": {
        "required": [
          "SCHOLARSENSE_AUDIT_INGESTION_POLICY_REF",
          "SCHOLARSENSE_AUDIT_HASH_PROFILE_REF",
          "SCHOLARSENSE_AUDIT_COLLECTOR_REF",
          "SCHOLARSENSE_AUDIT_VERIFIER_REF",
          "SCHOLARSENSE_AUDIT_ALERT_TRANSPORT_REF",
          "SCHOLARSENSE_AUDIT_METRIC_BINDING_REF",
          "SCHOLARSENSE_AUDIT_RETENTION_CAPABILITY_REF"
        ]
      }
    }
  ]
}
